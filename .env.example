# ── NextAuth (required) ─────────────────────────────────────────────
# Full public URL of the deployed site (used for OAuth callbacks).
NEXTAUTH_URL=https://aiverse.nesr.com
# Long random string used to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Microsoft Entra ID (OIDC) ───────────────────────────────────────
# Provided by NESR IT once the app is registered in Entra.
# When CLIENT_ID and TENANT_ID are set, the "Sign in with Microsoft"
# button turns on automatically — no code change needed.
# Redirect URI to register: https://aiverse.nesr.com/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ── Interim / break-glass shared login ──────────────────────────────
# Used until SSO is live (and as a fallback afterwards). Change in prod.
LEARNAI_USER=nesrai
LEARNAI_PASS=nesr123456

# ── AIverse assistant (n8n chat) ────────────────────────────────────
# When set, /api/chat forwards the conversation to this n8n webhook and
# returns its reply. Until then, the chat shows a "not connected yet" note.
# The webhook should respond with JSON: { "reply": "..." } (or output/text).
N8N_CHAT_WEBHOOK_URL=
# Optional bearer token sent to the webhook (Authorization: Bearer ...).
N8N_CHAT_WEBHOOK_TOKEN=
# Rate limits (per user). Burst window (anti-spam) + daily cap (cost control).
CHAT_RATE_LIMIT=10
CHAT_RATE_WINDOW_MS=60000
CHAT_DAILY_LIMIT=100
