# ── NextAuth (required) ─────────────────────────────────────────────
# Full public URL of the deployed site (used for OAuth callbacks).
NEXTAUTH_URL=https://upskillai.nesr.com
# Long random string used to sign session tokens. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Microsoft Entra ID (OIDC) ───────────────────────────────────────
# Provided by NESR IT once the app is registered in Entra.
# When CLIENT_ID and TENANT_ID are set, the "Sign in with Microsoft"
# button turns on automatically — no code change needed.
# Redirect URI to register: https://upskillai.nesr.com/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ── Interim / break-glass shared login ──────────────────────────────
# Used until SSO is live (and as a fallback afterwards). Change in prod.
LEARNAI_USER=nesrai
LEARNAI_PASS=nesr123456
